String getReminderSummary(int idx) {
  if (idx < 0 || idx >= numReminders) return "Invalid";
  char buf[6];
  snprintf(buf, sizeof(buf), "%02d:%02d", reminders[idx].hour, reminders[idx].minute);
  return "#" + String(idx) + " " + reminders[idx].label + " @ " + String(buf);
}

void deleteReminder(int idx) {
  if (idx < 0 || idx >= numReminders) return;
  for (int i = idx; i < numReminders - 1; i++) {
    reminders[i] = reminders[i + 1];
  }
  numReminders--;
  if (numReminders == 0) {
    selectedReminderIndex = 0;
  } else if (selectedReminderIndex >= numReminders) {
    selectedReminderIndex = numReminders - 1;
  }
  if (activeIndex == idx) {
    activeIndex = -1;
    robotState  = IDLE;
    stopMotors();
    showEmotion("neutral");
  } else if (activeIndex > idx) {
    activeIndex--;
  }
}

// ============================================================
// BLYNK HANDLERS
// V0  = status terminal/label
// V1  = snooze button
// V2  = confirm button
// V3  = hour input
// V4  = minute input
// V5  = snooze minute input
// V6  = reminder type
// V7  = add reminder
// V8  = move forward
// V9  = move backward
// V10 = turn left
// V11 = turn right
// V12 = stop
// V13 = off today
// V14 = permanent disable/enable
// V15 = delete
// V16 = select reminder index
// ============================================================
BLYNK_WRITE(V1) {
  if (param.asInt() == 1 && (robotState == WAITING_RESPONSE || robotState == SNOOZED))
    doSnooze();
}

BLYNK_WRITE(V2) {
  if (param.asInt() == 1 && robotState == WAITING_RESPONSE) doConfirm();
}

BLYNK_WRITE(V3) { newReminderHour = param.asInt(); }
BLYNK_WRITE(V4) { newReminderMin  = param.asInt(); }
BLYNK_WRITE(V5) { snoozeMinutes   = constrain(param.asInt(), 1, 60); }
BLYNK_WRITE(V6) { newReminderType = param.asInt(); }

BLYNK_WRITE(V7) {
  if (param.asInt() != 1) return;
  if (numReminders >= MAX_REMINDERS) {
    safeBlynkWrite(V0, "Reminder list full.");
    return;
  }
  if (newReminderHour < 0 || newReminderHour > 23 ||
      newReminderMin  < 0 || newReminderMin  > 59) {
    safeBlynkWrite(V0, "Invalid reminder time.");
    return;
  }
  String lbl, msg;
  int    trk;
  if (newReminderType == 0) {
    lbl = "Medicine"; msg = "Time to take your medicine!";    trk = TRACK_MEDICINE;
  } else if (newReminderType == 1) {
    lbl = "Meal";     msg = "Time to eat your meal!";         trk = TRACK_MEAL;
  } else {
    lbl = "Reminder"; msg = "You have a scheduled task!";     trk = TRACK_GENERAL;
  }
  for (int i = 0; i < numReminders; i++) {
    if (reminders[i].hour   == newReminderHour &&
        reminders[i].minute == newReminderMin  &&
        reminders[i].label  == lbl) {
      safeBlynkWrite(V0, "Reminder already exists.");
      return;
    }
  }
  reminders[numReminders] = {
    newReminderHour, newReminderMin, lbl, msg, trk, false, false, false
  };
  numReminders++;
  saveReminders();
  char buf[6];
  snprintf(buf, sizeof(buf), "%02d:%02d", newReminderHour, newReminderMin);
  String info = "Added: " + lbl + " at " + String(buf);
  Serial.println(info);
  safeBlynkWrite(V0, info);
  showMessage("Reminder Added", lbl + " at " + String(buf));
  responsiveDelay(1000, false);
  showEmotion("neutral");
}

