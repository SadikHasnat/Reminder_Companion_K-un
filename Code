void stopReminderAudio() {
  if (dfReady) dfPlayer.stop();
}

void servoConfirmGesture() {
  armServo.write(0);
  responsiveDelay(200, false);
  armServo.write(90);
  responsiveDelay(350, false);
  armServo.write(0);
  responsiveDelay(250, false);
}

void waveArm() {
  for (int i = 0; i < 2; i++) {
    armServo.write(0);
    responsiveDelay(180, false);
    armServo.write(90);
    responsiveDelay(180, false);
  }
  armServo.write(0);
}

void cheerfulAction() {
  if (dfReady) dfPlayer.play(TRACK_CHEER);
  servoConfirmGesture();
}

// ============================================================
// MOTOR SAFETY + CONTROL
// ============================================================
bool floorIsSafe() {
  return digitalRead(IR_FALL_PIN) == FLOOR_SAFE;
}

bool frontIsClear() {
  return digitalRead(IR_OBSTACLE_PIN) != OBSTACLE_DETECTED;
}

bool canMoveForwardSafely() {
  return floorIsSafe() && frontIsClear();
}

bool canMoveBasicSafely() {
  return floorIsSafe();
}

bool touchIsPressed() {
  return touchRead(TOUCH_PIN) < TOUCH_THRESH;
}

void moveForward() {
  moveForwardSpeed(MOTOR_SPEED);
}

void moveForwardSlow() {
  moveForwardSpeed(SLOW_MOTOR_SPEED);
}

void moveForwardSpeed(int speed) {
  if (!canMoveForwardSafely()) {
    stopMotors();
    Serial.println("Forward blocked by sensor.");
    safeBlynkWrite(V0, "Forward blocked: obstacle or no ground.");
    return;
  }
  speed = constrain(speed, 0, 255);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
  analogWrite(ENA, speed);
  analogWrite(ENB, speed);
}

void moveBackward() {
  if (!canMoveBasicSafely()) {
    stopMotors();
    Serial.println("Backward blocked by edge sensor.");
    safeBlynkWrite(V0, "Backward blocked: no ground.");
    return;
  }
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, MOTOR_SPEED);
  analogWrite(ENB, MOTOR_SPEED);
}

void turnLeft() {
  if (!canMoveBasicSafely()) {
    stopMotors();
    Serial.println("Left turn blocked by edge sensor.");
    safeBlynkWrite(V0, "Left turn blocked: no ground.");
    return;
  }
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
  analogWrite(ENA, MOTOR_SPEED);
  analogWrite(ENB, MOTOR_SPEED);
}

void turnRight() {
  if (!canMoveBasicSafely()) {
    stopMotors();
    Serial.println("Right turn blocked by edge sensor. Use recovery logic.");
    safeBlynkWrite(V0, "Right turn blocked: no ground.");
    return;
  }
  turnRightRaw(MOTOR_SPEED);
}

void turnRightRaw(int speed) {
  speed = constrain(speed, 0, 255);
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
  analogWrite(ENA, speed);
  analogWrite(ENB, speed);
}

void stopMotors() {
  analogWrite(ENA, 0);
  analogWrite(ENB, 0);
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}
