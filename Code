// ============================================================
// SETUP
// ============================================================
void setup() {
  Serial.begin(115200);
  Wire.begin(SDA_PIN, SCL_PIN);

  loadReminders();

  if (!display.begin(SSD1306_SWITCHCAPVCC, OLED_ADDR)) {
    Serial.println("OLED init failed.");
    while (true) delay(10);
  }
  showEmotion("neutral");

  if (!rtc.begin()) {
    Serial.println("RTC not found.");
    showMessage("RTC Error", "Check SDA/SCL wiring.");
    while (true) delay(10);
  }
  if (rtc.lostPower()) {
    rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
  }

  dfSerial.begin(9600, SERIAL_8N1, DF_RX, DF_TX);
  delay(500);
  if (!dfPlayer.begin(dfSerial)) {
    Serial.println("DFPlayer failed.");
    dfReady = false;
  } else {
    dfPlayer.volume(25);
    dfReady = true;
  }

  armServo.attach(SERVO_PIN);
  armServo.write(0);

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(ENA, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(ENB, OUTPUT);
  stopMotors();

  pinMode(PIR_PIN,         INPUT);
  pinMode(IR_OBSTACLE_PIN, INPUT);
  pinMode(IR_FALL_PIN,     INPUT);

  connectWiFi();
  connectBlynk();
  safeBlynkWrite(V0, "Robot Ready.");

  showEmotion("happy");
  if (dfReady) dfPlayer.play(TRACK_CHEER);
  waveArm();
  responsiveDelay(500, false);
  showEmotion("neutral");

  timer.setInterval(200L,   robotTask);
  timer.setInterval(10000L, connectBlynkIfNeeded);

  Serial.println("Reminder Companion Robot started.");
}

// ============================================================
// LOOP — FIXED
// Removed redundant direct call to connectBlynkIfNeeded();
// the timer already calls it every 10 seconds.
// ============================================================
void loop() {
  Blynk.run();
  timer.run();
}

// ============================================================
// MAIN ROBOT TASK
// ============================================================
void robotTask() {
  DateTime now = rtc.now();
  resetTriggersAtMidnight(now);

  // Priority 1: safety always runs first.
  checkSensors();

  // Reminder has priority over PIR greeting and normal navigation.
  checkReminders(now);
  checkTouchSensor();

  // PIR greeting only works when no reminder is active.
  handlePirSensor();

  // If nothing special is happening, keep navigating normally.
  normalNavigationStep();
  updateIdleDisplay(now);
}

// ============================================================
// MIDNIGHT RESET
// ============================================================
void resetTriggersAtMidnight(DateTime now) {
  static int lastDay = -1;
  if (now.day() != lastDay) {
    lastDay = now.day();
    for (int i = 0; i < numReminders; i++) {
      reminders[i].triggeredToday = false;
      reminders[i].skippedToday  = false;
    }
    Serial.println("Daily reminder flags reset.");
  }
}

// ============================================================
// REMINDER LOGIC
// ============================================================
void checkReminders(DateTime now) {
  if (fallDetected) return;

  if (robotState == SNOOZED && timeReached(snoozeUntil)) {
    if (activeIndex < 0 || activeIndex >= numReminders ||
        reminders[activeIndex].disabled ||
        reminders[activeIndex].skippedToday) {
      robotState  = IDLE;
      activeIndex = -1;
      stopMotors();
      safeBlynkWrite(V0, "Snoozed reminder is off/disabled.");
      return;
    }
    reminderRetryStage = 0;
    triggerReminder(activeIndex);
    return;
  }

  if (robotState == WAITING_RESPONSE &&
      activeIndex >= 0 &&
      timeReached(nextReminderAction)) {
    handleReminderTimeout();
    return;
  }

  // Reminder can interrupt PIR interaction, but not confirming/snoozed/waiting states.
  if (robotState != IDLE && robotState != PIR_INTERACTION) return;

  for (int i = 0; i < numReminders; i++) {
    if (reminders[i].disabled)      continue;
    if (reminders[i].skippedToday)  continue;
    if (reminders[i].triggeredToday) continue;
    if (now.hour()   == reminders[i].hour &&
        now.minute() == reminders[i].minute) {
      if (robotState == PIR_INTERACTION) {
        stopMotors();
        robotState = IDLE;
      }
      reminders[i].triggeredToday = true;
      activeIndex        = i;
      reminderRetryStage = 0;
      triggerReminder(i);
      return;
    }
  }
}

void triggerReminder(int idx) {
  if (idx < 0 || idx >= numReminders) {
    robotState  = IDLE;
    activeIndex = -1;
    safeBlynkWrite(V0, "Invalid reminder index.");
    return;
  }
  if (reminders[idx].disabled || reminders[idx].skippedToday) {
    robotState  = IDLE;
    activeIndex = -1;
    return;
  }
  robotState       = WAITING_RESPONSE;
  activeIndex      = idx;
  autoMotionActive = false;
  stopMotors();
  nextReminderAction = millis() + CONFIRM_TIMEOUT_MS;
  Serial.println("REMINDER: " + reminders[idx].message);
  showReminderScreen(idx, "REMINDER");
  if (dfReady) dfPlayer.play(reminders[idx].track);
  safeBlynkWrite(V0, reminders[idx].message + " | Touch to confirm.");
}

void handleReminderTimeout() {
  if (activeIndex < 0 || activeIndex >= numReminders) {
    robotState  = IDLE;
    activeIndex = -1;
    return;
  }
  if (reminders[activeIndex].disabled || reminders[activeIndex].skippedToday) {
    robotState  = IDLE;
    activeIndex = -1;
    stopMotors();
    return;
  }

  if (reminderRetryStage == 0) {
    // First no-response: sad face, wait 5 minutes before replay.
    reminderRetryStage = 1;
    stopReminderAudio();
    showEmotion("sad");
    nextReminderAction = millis() + RETRY_WAIT_MS;
    safeBlynkWrite(V0, "No touch detected. Reminder will replay in 5 minutes.");
    return;
  }

  if (reminderRetryStage == 1) {
    // Replay the reminder after sad waiting period.
    reminderRetryStage = 2;
    showReminderScreen(activeIndex, "REMINDER AGAIN");
    if (dfReady) dfPlayer.play(reminders[activeIndex].track);
    nextReminderAction = millis() + RETRY_WAIT_MS;
    safeBlynkWrite(V0, "Reminder replayed. Waiting for touch.");
    return;
  }

  // After replay, no touch = angry retry mode every 5 minutes until confirmed.
  reminderRetryStage = 3;
  showEmotion("angry");
  if (dfReady) dfPlayer.play(reminders[activeIndex].track);
  nextReminderAction = millis() + RETRY_WAIT_MS;
  safeBlynkWrite(V0, "Still no confirmation. Angry retry mode. Repeating every 5 minutes.");
}

void checkTouchSensor() {
  if (robotState != WAITING_RESPONSE) return;
  if (touchIsPressed()) {
    doConfirm();
  }
}

void doConfirm() {
  if (activeIndex >= 0 && activeIndex < numReminders) {
    reminders[activeIndex].triggeredToday = true;
  }
  robotState         = CONFIRMING;
  reminderRetryStage = 0;
  stopMotors();
  stopReminderAudio();
  Serial.println("Reminder confirmed.");
  showEmotion("happy");
  if (dfReady) dfPlayer.play(TRACK_CONFIRM);
  servoConfirmGesture();
  safeBlynkWrite(V0, "Task confirmed and marked done.");
  responsiveDelay(1000, false);
  robotState  = IDLE;
  activeIndex = -1;
  showEmotion("neutral");
}

void doSnooze() {
  if (activeIndex < 0 || activeIndex >= numReminders) {
    robotState = IDLE;
    return;
  }
  stopMotors();
  stopReminderAudio();
  robotState         = SNOOZED;
  snoozeUntil        = millis() + ((unsigned long)snoozeMinutes * 60000UL);
  reminderRetryStage = 0;
  Serial.println("Snoozed for " + String(snoozeMinutes) + " minute(s).");
  showMessage("Snoozed", "Again in " + String(snoozeMinutes) + " min.");
  showEmotion("sleepy");
  if (dfReady) dfPlayer.play(TRACK_SNOOZE);
  safeBlynkWrite(V0, "Snoozed for " + String(snoozeMinutes) + " min.");
  responsiveDelay(1000, false);
  showEmotion("neutral");
}

// ============================================================
// SENSOR + PIR + NAVIGATION LOGIC
// ============================================================
void checkSensors() {
  // Priority 1: ground detection always wins.
  if (!floorIsSafe()) {
    fallDetected = true;
    handleFallDetected();
    return;
  }
  if (fallDetected) {
    fallDetected = false;
    Serial.println("Safe floor detected again.");
    safeBlynkWrite(V0, "Safe ground detected.");
    showEmotion(robotState == WAITING_RESPONSE ? "alert" : "neutral");
  }
  // Priority 2: front obstacle, only after ground is safe.
  if (!frontIsClear()) {
    if (!obstacleDetected) {
      obstacleDetected = true;
      handleObstacle();
    }
  } else {
    obstacleDetected = false;
  }
}

void handleObstacle() {
  stopMotors();
  autoMotionActive = false;
  Serial.println("Obstacle detected. Turning right until path is clear.");
  showEmotion("surprised");
  safeBlynkWrite(V0, "Obstacle detected. Turning right.");
  if (!manualMotorControl && floorIsSafe() &&
      (robotState == IDLE || robotState == PIR_INTERACTION)) {
    obstacleAvoidManeuver();
  } else {
    responsiveDelay(250, false);
  }
  showEmotion(robotState == WAITING_RESPONSE ? "alert" : "neutral");
}

void handleFallDetected() {
  stopMotors();
  autoMotionActive   = false;
  manualMotorControl = false;
  Serial.println("NO GROUND detected. Turning right until ground is found.");
  display.clearDisplay();
  display.setTextColor(SSD1306_WHITE);
  display.fillRect(0, 0, 128, 14, SSD1306_WHITE);
  display.setTextColor(SSD1306_BLACK);
  display.setTextSize(1);
  display.setCursor(16, 3);
  display.print("NO GROUND");
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(4, 20);
  display.print("Stop -> Turn Right");
  display.setCursor(4, 34);
  display.print("Searching ground...");
  display.display();
  safeBlynkWrite(V0, "No ground detected. Turning right until ground is found.");
  recoverGroundByTurningRight();
}

void recoverGroundByTurningRight() {
  if (avoidanceRunning) return;
  avoidanceRunning = true;
  stopMotors();
  responsiveDelay(100, false);
  while (!floorIsSafe()) {
    Blynk.run();
    timer.run();
    connectBlynkIfNeeded();
    // Raw turn used here because normal turnRight() refuses when ground is unsafe.
    turnRightRaw(TURN_MOTOR_SPEED);
    delay(250);
    stopMotors();
    delay(80);
  }
  stopMotors();
  fallDetected     = false;
  obstacleDetected = false;
  avoidanceRunning = false;
  showMessage("Ground Found", "Safe floor detected.");
  safeBlynkWrite(V0, "Ground found. Robot can continue.");
  responsiveDelay(500, false);
}

void obstacleAvoidManeuver() {
  if (avoidanceRunning) return;
  avoidanceRunning = true;
  stopMotors();
  responsiveDelay(150, false);
  while (floorIsSafe() && !frontIsClear()) {
    turnRightRaw(TURN_MOTOR_SPEED);
    delay(350);
    stopMotors();
    delay(100);
    Blynk.run();
    timer.run();
    connectBlynkIfNeeded();
  }
  stopMotors();
  if (!floorIsSafe()) {
    avoidanceRunning = false;
    handleFallDetected();
    return;
  }
  obstacleDetected = false;
  avoidanceRunning = false;
  safeBlynkWrite(V0, "Path clear. Moving forward.");
}

void autonomousForwardStep(unsigned long ms) {
  if (manualMotorControl || fallDetected) return;
  if (!canMoveForwardSafely()) {
    checkSensors();
    return;
  }
  autoMotionActive = true;
  moveForward();
  responsiveDelay(ms, true);
  stopMotors();
  autoMotionActive = false;
}

void normalNavigationStep() {
  if (manualMotorControl)  return;
  if (avoidanceRunning)    return;
  if (fallDetected)        return;
  // Normal navigation only when no reminder or PIR interaction is active.
  if (robotState != IDLE)  return;
  if (!floorIsSafe()) {
    checkSensors();
    return;
  }
  if (!frontIsClear()) {
    handleObstacle();
    return;
  }
  if (!autoMotionActive) {
    autoMotionActive = true;
    moveForward();
  }
}

void handlePirSensor() {
  // Reminder has higher priority than PIR greeting.
  if (robotState == WAITING_RESPONSE ||
      robotState == CONFIRMING       ||
      robotState == SNOOZED) return;

  if (robotState == PIR_INTERACTION) {
    stopMotors();
    if (touchIsPressed()) {
      finishPirInteraction();
      return;
    }
    if (timeReached(pirWaitUntil)) {
      robotState = IDLE;
      showEmotion("neutral");
      safeBlynkWrite(V0, "PIR interaction timed out. Returning to navigation.");
    }
    return;
  }

  if (robotState != IDLE) return;
  if (digitalRead(PIR_PIN) == HIGH) {
    startPirInteraction();
  }
}

void startPirInteraction() {
  robotState       = PIR_INTERACTION;
  autoMotionActive = false;
  stopMotors();
  showMessage("Person Detected", "Moving slowly...");
  safeBlynkWrite(V0, "Person detected by PIR.");
  if (canMoveForwardSafely()) {
    moveForwardSlow();
    responsiveDelay(PIR_APPROACH_MS, true);
  }
  stopMotors();
  showMessage("Person Detected", "Touch sensor to greet.");
  pirWaitUntil = millis() + PIR_WAIT_MS;
}

void finishPirInteraction() {
  stopMotors();
  showEmotion("happy");
  servoConfirmGesture();
  safeBlynkWrite(V0, "Person interaction confirmed by touch.");
  responsiveDelay(700, false);
  robotState = IDLE;
  showEmotion("neutral");
}

