BLYNK_WRITE(V14) {
  if (param.asInt() != 1) return;
  if (numReminders == 0) {
    safeBlynkWrite(V0, "No reminders exist.");
    return;
  }
  if (selectedReminderIndex < 0 || selectedReminderIndex >= numReminders) {
