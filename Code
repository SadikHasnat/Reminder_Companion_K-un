// ============================================================
void copyStringToChar(char *dest, size_t len, const String &src) {
  strncpy(dest, src.c_str(), len - 1);
  dest[len - 1] = '\0';
}

void saveReminders() {
  prefs.begin("reminders", false);
  prefs.putInt("count", numReminders);
  for (int i = 0; i < numReminders; i++) {
    StoredReminder sr;
    sr.hour     = reminders[i].hour;
    sr.minute   = reminders[i].minute;
    sr.track    = reminders[i].track;
    sr.disabled = reminders[i].disabled;
    copyStringToChar(sr.label,   STORE_LABEL_LEN, reminders[i].label);
    copyStringToChar(sr.message, STORE_MSG_LEN,   reminders[i].message);
    String key = "r" + String(i);
    prefs.putBytes(key.c_str(), &sr, sizeof(sr));
  }
  prefs.end();
  Serial.println("Reminders saved.");
}

bool loadReminders() {
  prefs.begin("reminders", true);
  int savedCount = prefs.getInt("count", -1);
  if (savedCount < 0 || savedCount > MAX_REMINDERS) {
    prefs.end();
    Serial.println("No saved reminders. Using defaults.");
    return false;
  }
  numReminders = savedCount;
  for (int i = 0; i < numReminders; i++) {
    StoredReminder sr;
    String key       = "r" + String(i);
    size_t bytesRead = prefs.getBytes(key.c_str(), &sr, sizeof(sr));
    if (bytesRead == sizeof(sr)) {
      reminders[i].hour          = sr.hour;
      reminders[i].minute        = sr.minute;
      reminders[i].track         = sr.track;
      reminders[i].disabled      = sr.disabled;
      reminders[i].label         = String(sr.label);
      reminders[i].message       = String(sr.message);
      reminders[i].triggeredToday = false;
      reminders[i].skippedToday  = false;
    }
  }
  prefs.end();
  Serial.println("Reminders loaded.");
  return true;
}

// ============================================================
// WIFI — FIXED
// Retries on dropout; skips if already connected.
// ============================================================
void connectWiFi() {
  if (WiFi.status() == WL_CONNECTED) return;
  WiFi.mode(WIFI_STA);
  WiFi.begin(ssid, pass);
  Serial.println("[WiFi] Connecting...");
  unsigned long start = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - start < 15000UL) {
    delay(500);
    Serial.print(".");
  }
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] Connected: " + WiFi.localIP().toString());
  } else {
    Serial.println("\n[WiFi] Connection FAILED. Will retry later.");
  }
}

// ============================================================
// BLYNK — FIXED
// Guards against double-connect; uses config+connect pattern.
// ============================================================
void connectBlynk() {
  if (WiFi.status() != WL_CONNECTED) return;
  if (Blynk.connected()) return;
  Serial.println("[Blynk] Attempting connection...");
  Blynk.config(BLYNK_AUTH_TOKEN);
  if (Blynk.connect(5000)) {
    Serial.println("[Blynk] Connected!");
    blynkConfigured = true;
  } else {
    Serial.println("[Blynk] Failed. Will retry later.");
  }
}

// ============================================================
// CONNECT BLYNK IF NEEDED — FIXED
// Called by timer every 10 seconds; handles both WiFi and Blynk dropout.
// ============================================================
void connectBlynkIfNeeded() {
  unsigned long now = millis();
  // Step 1: check and recover WiFi first.
  if (WiFi.status() != WL_CONNECTED) {
    if (now - lastWiFiReconnectAttempt >= WIFI_RECONNECT_MS) {
      lastWiFiReconnectAttempt = now;
      Serial.println("[WiFi] Lost connection. Reconnecting...");
      WiFi.disconnect();
      connectWiFi();
    }
    return; // No point trying Blynk without WiFi.
  }
  // Step 2: reconnect Blynk if WiFi is fine but Blynk dropped.
  if (!Blynk.connected()) {
    if (now - lastBlynkReconnectAttempt >= BLYNK_RECONNECT_MS) {
      lastBlynkReconnectAttempt = now;
      Serial.println("[Blynk] Disconnected. Reconnecting...");
      connectBlynk();
    }
  }
}

// ============================================================
// SAFE BLYNK WRITE — FIXED
// Guards every virtual write so disconnected state never crashes.
// ============================================================
void safeBlynkWrite(int pin, const String &value) {
  if (!Blynk.connected()) {
    Serial.println("[Blynk] Skipped write to V" + String(pin) + ": not connected.");
    return;
  }
  Blynk.virtualWrite(pin, value);
}

// ============================================================
// UTILITY
// ============================================================
bool timeReached(unsigned long target) {
  return (long)(millis() - target) >= 0;
}

void responsiveDelay(unsigned long ms, bool checkSafety) {
  unsigned long start = millis();
  while (millis() - start < ms) {
    Blynk.run();
    timer.run();
    if (checkSafety) {
      if (!floorIsSafe()) { stopMotors(); return; }
      if (!frontIsClear()) { stopMotors(); return; }
    }
    delay(10);
  }
}

